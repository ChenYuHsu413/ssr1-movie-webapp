# Copy this file to .env and fill in your key. .env is loaded automatically on startup.

# Groq (preferred). Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
# Optional: override the Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Alternatively, use Anthropic Claude instead of Groq:
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Or use Google Gemini. Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_key_here
# Optional: override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
